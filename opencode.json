{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "external_directory": "deny",
    "skill": {
      "*": "allow",
      "goal-contract": "ask",
      "grill-requirements": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".agents/skills/**",
      ".claude/skills/**",
      "node_modules/**",
      "dist/**",
      "output/**"
    ]
  }
}

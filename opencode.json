{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "rg *": "allow",
      "python3 scripts/check_*": "allow",
      "node --check *": "allow",
      "bash -n *": "allow",
      "shellcheck *": "allow"
    },
    "external_directory": "deny",
    "skill": {
      "*": "allow",
      "goal-contract": "ask",
      "grill-requirements": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".agents/skills/**",
      ".claude/skills/**",
      "node_modules/**",
      "dist/**",
      "output/**"
    ]
  }
}
